{
    "hosting": {
        "public": ".",
        "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
        "rewrites": [
            { "source": "/api/searchFoods", "function": "searchFoods" },
            { "source": "/api/getFoodById", "function": "getFoodById" }
        ]
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "disallowLegacyRuntimeConfig": true,
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ]
}
